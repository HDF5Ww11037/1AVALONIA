<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d" d:DesignWidth="800" d:DesignHeight="450"
        x:Class="AVALONIA_CHMO.MainWindow"
        Width="450"
        Height="300"
        CanResize="False"
        Title="Котлярова Саша xd">
        <StackPanel> 
                <TextBlock FontSize="30" HorizontalAlignment="Center" Text="Котлярова Саша:)"/>
                <TextBlock FontSize="25" HorizontalAlignment="Center" Text="Учусь в 8 классе, 15 лет"/>
                <TextBlock Name="Zet" IsVisible="False" FontSize="23" HorizontalAlignment="Center" Text="Не придумала````"/>
                <Button Click="Button_OnClick" Content="доп.инфо" HorizontalAlignment="Center"/>
                <Button Click="Button_OnClick_Close" Content="Закрыть" HorizontalAlignment="Center"/>
        </StackPanel>
</Window>